def are_anagrams(s1, s2):
    text1 = ""
    text2 = ""

    # Remove spaces and symbols, and make lowercase
    for letter in s1:
        if letter.isalnum():
            text1 += letter.lower()

    for letter in s2:
        if letter.isalnum():
            text2 += letter.lower()

    # Check if the lengths are the same
    if len(text1) != len(text2):
        return False

    # Check each letter
    for letter in text1:
        if text1.count(letter) != text2.count(letter):
            return False

    return True


# Ask the user to enter two texts
first = input("Enter the first text: ")
second = input("Enter the second text: ")

# Display the result
if are_anagrams(first, second):
    print("They are anagrams.")
else:
    print("They are not anagrams.")
